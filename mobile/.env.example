EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_APP_SLUG=agentapp

# Mirrors backend's TEAMS_ENABLED. Set "false" to hide the Teams tab and
# the Settings team-switcher card. Routes still resolve so deep links
# (e.g. invite acceptance) keep working.
EXPO_PUBLIC_TEAMS_ENABLED=true

# LOCAL DEV ONLY — when "true", on first launch the app fires
# POST /auth/login with EXPO_PUBLIC_DEV_AUTO_LOGIN_EMAIL (default
# "dev@local") and skips the magic-link sign-in screen entirely. Pairs
# with the backend's AUTH_DEV_BYPASS_EMAIL but works independently
# (this path uses the real /auth/login + JWT flow). Leave "false" in
# shipped builds — the env var lands in the bundle and is unsupported
# in production.
EXPO_PUBLIC_DEV_AUTO_LOGIN=false
EXPO_PUBLIC_DEV_AUTO_LOGIN_EMAIL=dev@local
