PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5434/agent_app?sslmode=disable
APP_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

JWT_SECRET=dev-secret-change-me-please-use-a-long-random-value
AUTH_EMAIL_FROM=Agent App <onboarding@example.com>
RESEND_API_KEY=
MOBILE_APP_SCHEME=agentapp

# Anthropic — run `make managed-agents-provision` to get these values
ANTHROPIC_API_KEY=
ANTHROPIC_AGENT_ID=
ANTHROPIC_ENVIRONMENT_ID=

AGENT_SYSTEM_PROMPT=You are a helpful assistant.
AGENT_RUN_RATE_LIMIT=10
AGENT_RUN_RATE_WINDOW_SECONDS=60

# --- Local code-generation agent (OPTIONAL) --------------------------------
# Pluggable wrapper around `claude` (and any other prompt-on-stdin coding-agent
# CLI) via github.com/teslashibe/codegen-go. Used by `cmd/codegen-demo` and any
# code that calls `internal/codegen.LoadFromEnv()`. Independent of the
# Anthropic Managed Agents path above; leave commented out if you only use
# Managed Agents.
# CODEGEN_AGENT=claude-code             # claude-code (default) | generic
# CODEGEN_MODEL=claude-sonnet-4-5       # optional --model override
# CODEGEN_TIMEOUT=30m                   # per-run cap
# CODEGEN_MAX_OUTPUT_BYTES=10485760     # cap captured stdout+stderr (10 MiB)
# CODEGEN_COMMAND=                      # generic only: binary path
# CODEGEN_ARGS=                         # generic only: comma-separated argv

# Teams — multi-tenant collaboration with Owner / Admin / Member roles.
# When TEAMS_ENABLED is false the /api/teams and /api/invites routes are
# not mounted but personal teams still get auto-created on first login so
# agent endpoints continue to function.
TEAMS_ENABLED=true
TEAMS_DEFAULT_MAX_SEATS=25
TEAMS_INVITE_TTL_HOURS=168
TEAMS_INVITE_FROM_NAME=Agent App

# Notifications — Android NotificationListenerService capture pipeline.
# When NOTIFICATIONS_ENABLED is false (default) the /api/notifications/*
# routes are not mounted, the notifications_* MCP tools are not registered
# on the per-user agent, and the mobile capture screen renders an
# "unavailable" state. The 00003_notification_events migration ships in
# every fork; the table simply stays empty. Enable this for clients who
# need the communication-rollup feature (e.g. real-estate-agent fork).
NOTIFICATIONS_ENABLED=false
NOTIFICATIONS_INGEST_RATE_LIMIT=60
NOTIFICATIONS_INGEST_RATE_WINDOW_SECONDS=60
NOTIFICATIONS_DEFAULT_PAGE_SIZE=50
NOTIFICATIONS_MAX_PAGE_SIZE=200
NOTIFICATIONS_ACTION_REPLY_WINDOW_HOURS=2

# Brand — selects which persona the per-user agent provisions with.
# Empty (default) means use the catch-all template prompt. Forks add
# their persona via internal/brand/<name>.go (init() calls
# brand.Register()) and set BRAND=<name> here. Unknown values log a
# warning and fall through to the default rather than failing boot.
BRAND=

# Local-dev convenience: set to an email to make every unauthenticated
# request authenticate as that user. The user record + personal team
# are pre-created at boot, so curl/Postman/scripts can hit /api/* with
# no JWT plumbing. LEAVE BLANK in any deployed environment — the server
# logs a loud warning when this is set.
AUTH_DEV_BYPASS_EMAIL=
